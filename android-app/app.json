{
  "expo": {
    "name": "Nikon Dashboard",
    "slug": "jipesyaalta",
    "owner": "jipesya",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "nikondashboard",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFE500"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nikondashboard.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Digunakan untuk scan QR absensi event"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFE500"
      },
      "package": "com.nikondashboard.app",
      "permissions": ["android.permission.CAMERA"],
      "minSdkVersion": 24,
      "versionCode": 2
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Digunakan untuk scan QR absensi event Nikon"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "92ceb354-ea33-4b35-a0ae-eef1f52685c7"
      }
    }
  }
}
